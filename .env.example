# =============================================================================
# CVERiskPilot Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cveriskpilot?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth (Auth.js / NextAuth) ---
AUTH_SECRET="generate-a-64-char-random-hex-string"

# --- Google OIDC ---
GOOGLE_OIDC_CLIENT_ID=""
GOOGLE_OIDC_CLIENT_SECRET=""
GOOGLE_OIDC_ORGANIZATION_ID=""
GOOGLE_OIDC_EMAIL_DOMAINS=""
GOOGLE_OIDC_MODE="optional"
GOOGLE_OIDC_ALLOW_JIT_PROVISIONING="true"
GOOGLE_OIDC_ALLOW_LOCAL_PASSWORD_LOGIN="true"

# --- WorkOS Enterprise SSO ---
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
WORKOS_REDIRECT_URI="http://localhost:3000/api/auth/workos/callback"

# --- GCS (Google Cloud Storage) ---
GCS_BUCKET_ARTIFACTS="cveriskpilot-artifacts-dev"
GCS_PROJECT_ID=""

# --- AI: Anthropic Claude ---
ANTHROPIC_API_KEY=""

# --- Billing: Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_FOUNDERS_BETA_MONTHLY=""
STRIPE_PRICE_FOUNDERS_BETA_ANNUAL=""

# --- Email (Resend/SMTP) ---
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="true"
RESEND_API_KEY=""

# --- NVD API (optional, increases rate limit) ---
NVD_API_KEY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"
APP_NAME="CVERiskPilot"
APP_ENV="development"
NODE_ENV="development"

# --- Encryption ---
APP_ENCRYPTION_KEY=""

# --- Feature Flags ---
FEATURE_SSO_ENABLED="false"
FEATURE_WORKOS_SSO="false"
FEATURE_BETA_OPEN_ACCESS="false"
BILLING_TESTING_CONTROLS_ENABLED="false"
