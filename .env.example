# =============================================================================
# CVERiskPilot Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local
# =============================================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cveriskpilot?schema=public"
# DATABASE_REPLICA_URLS=""  # Comma-separated read replica URLs (optional)
# PGBOUNCER_HOST=""          # PgBouncer connection pooler host (optional)
# PGBOUNCER_PORT="6432"      # PgBouncer port (optional)
# PGBOUNCER_POOL_MODE="transaction"  # PgBouncer pool mode (optional)

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth (Auth.js / NextAuth) ---
AUTH_SECRET="generate-a-64-char-random-hex-string"

# --- Google OIDC ---
GOOGLE_OIDC_CLIENT_ID=""
GOOGLE_OIDC_CLIENT_SECRET=""
GOOGLE_OIDC_ORGANIZATION_ID=""
GOOGLE_OIDC_EMAIL_DOMAINS=""
GOOGLE_OIDC_MODE="optional"
GOOGLE_OIDC_ALLOW_JIT_PROVISIONING="true"
GOOGLE_OIDC_ALLOW_LOCAL_PASSWORD_LOGIN="true"

# --- WorkOS Enterprise SSO ---
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
WORKOS_REDIRECT_URI="http://localhost:3000/api/auth/workos/callback"

# --- GCP ---
GCP_PROJECT_ID=""
GCS_BUCKET_ARTIFACTS="cveriskpilot-artifacts-dev"

# --- Cloud Tasks (async job processing) ---
CLOUD_TASKS_LOCATION="us-central1"
CLOUD_TASKS_QUEUE="upload-processing"
WORKER_URL=""

# --- AI: Anthropic Claude ---
ANTHROPIC_API_KEY=""

# --- Billing: Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_FOUNDERS_BETA_MONTHLY=""
STRIPE_PRICE_FOUNDERS_BETA_ANNUAL=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_ANNUAL=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_ANNUAL=""
STRIPE_PRICE_MSSP_MONTHLY=""
STRIPE_PRICE_MSSP_ANNUAL=""
STRIPE_PRICE_MSSP_METERED=""

# --- Email (Resend/SMTP) ---
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="true"
RESEND_API_KEY=""

# --- NVD API (optional, increases rate limit) ---
NVD_API_KEY=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"
APP_NAME="CVERiskPilot"
APP_ENV="development"
NODE_ENV="development"

# --- Encryption ---
APP_ENCRYPTION_KEY=""

# --- Cron / Scheduled Jobs ---
CRON_SECRET=""

# --- Dev Tools ---
DEV_SESSION_ENABLED="false"

# --- Deployment Metadata ---
IMAGE_TAG=""
NEXT_PUBLIC_APP_VERSION=""

# --- Feature Flags ---
FEATURE_SSO_ENABLED="false"
FEATURE_WORKOS_SSO="false"
FEATURE_BETA_OPEN_ACCESS="false"
BILLING_TESTING_CONTROLS_ENABLED="false"

# --- Security (optional) ---
HIBP_ENABLED="false"                    # Check passwords against Have I Been Pwned
PASSKEY_CHALLENGE_TTL_MS="300000"        # WebAuthn challenge timeout (5 min default)
