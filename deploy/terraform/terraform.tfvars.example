# =============================================================================
# CVERiskPilot — Terraform Variables
# =============================================================================
# Copy to terraform.tfvars and fill in values.
# NEVER commit terraform.tfvars — it's in .gitignore.
# =============================================================================

project_id  = "your-gcp-project-id"
region      = "us-central1"
environment = "dev"

# Cloud SQL
db_tier     = "db-f1-micro"       # dev: db-f1-micro, prod: db-custom-2-8192
db_password = ""                   # Generate: openssl rand -base64 32

# Redis
redis_memory_size_gb = 1

# Container image (leave empty to use gcr.io/{project}/cveriskpilot-web:latest)
image_tag = ""

# Public URL (for auth callbacks, Stripe redirects)
app_url = "https://cveriskpilot.com"

# Monitoring
alert_email = ""

# Geo-blocking (ISO 3166-1 alpha-2 codes)
blocked_countries = []

# Google OAuth
google_oidc_client_id = ""  # From Google Cloud Console > APIs & Services > Credentials

# SMTP (outbound email)
smtp_host = ""              # e.g. smtp.resend.com
smtp_port = "587"
smtp_user = ""
smtp_from = "noreply@cveriskpilot.com"

# GitHub (for Cloud Build triggers)
github_owner = "cveriskpilot"
github_repo  = "cveriskpilot"
