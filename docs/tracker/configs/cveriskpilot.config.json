        "Canonical schema + ingestion service",
        "Initial dedup + basic UI",
        "Baseline RBAC",
        "1 CI scanner + 1 VM scanner integration",
        "Audit log MVP",
        "End-to-end ingest > case > ticket",
        "Idempotent ingestion verified",
        "Raw artifacts stored immutably"
      ],
      "mapsTo": "Phase 1 (MVP) + Phase 2"
    },
    {
      "title": "Staging",
      "cssClass": "staging",
      "duration": "6-10 weeks",
      "criteria": [
        "Multi-tenant hardening",
        "SSO integration + SCIM (optional)",
        "Retention policies enforced",
        "Performance / load testing",
        "Parser fuzzing + security testing",
        "SLOs defined and measured",
        "Pentest findings triaged"
      ],
      "mapsTo": "Phase 1 hardening + Phase 3"
    },
    {
      "title": "Pilot",
      "cssClass": "pilot",
      "duration": "8-12 weeks",
      "criteria": [
        "Customer portal MVP",
        "SLA policy/metrics dashboards",
        "Bug bounty + SIEM integrations",
        "Onboarding automation",
        "Support playbooks created",
        "Pilot tenants self-serve",
        "Ticket sync reliability >= threshold"
