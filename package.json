{
  "name": "@cveriskpilot/scan",
  "version": "0.1.14",
  "description": "Compliance as a Service CLI — scan dependencies, secrets, and IaC, then auto-map every finding to NIST 800-53, SOC 2, CMMC, FedRAMP, ASVS, and SSDF controls",
  "type": "module",
  "bin": {
    "cveriskpilot-scan": "./dist/cli.js",
    "crp-scan": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.publish.json",
    "type-check": "tsc --noEmit",
