// CVERiskPilot - Vulnerability Management SaaS Platform
// Prisma Schema - PostgreSQL with ULID-style CUID IDs

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  PLATFORM_ADMIN
  PLATFORM_SUPPORT
  ORG_OWNER
  SECURITY_ADMIN
  ANALYST
  DEVELOPER
  VIEWER
  SERVICE_ACCOUNT
  CLIENT_ADMIN
  CLIENT_VIEWER
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
  PENDING_INVITE
}

enum Tier {
  FREE
  FOUNDERS_BETA
  PRO
  ENTERPRISE
  MSSP
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

enum CaseStatus {
  NEW
  TRIAGE
  IN_REMEDIATION
  FIXED_PENDING_VERIFICATION
  VERIFIED_CLOSED
  REOPENED
  ACCEPTED_RISK
  FALSE_POSITIVE
  NOT_APPLICABLE
  DUPLICATE
}

enum UploadJobStatus {
  QUEUED
  PARSING
  ENRICHING
  BUILDING_CASES
  COMPLETED
  FAILED
}

enum AssetType {
  HOST
  REPOSITORY
  CONTAINER_IMAGE
  CLOUD_ACCOUNT
  APPLICATION
}

enum Environment {
  PRODUCTION
  STAGING
  DEVELOPMENT
}

enum Criticality {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ScannerType {
  SCA
  SAST
  DAST
  IAC
  CONTAINER
  VM
  BUG_BOUNTY
}

enum ParserFormat {
  NESSUS
  SARIF
  CSV
  JSON_FORMAT
  CYCLONEDX
  OSV
  SPDX
  CSAF
  QUALYS
  OPENVAS
  XLSX
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  STATE_CHANGE
  RISK_EXCEPTION
  EXPORT
  LOGIN
  LOGOUT
}

enum TeamRole {
  OWNER
  MEMBER
}

enum ExceptionType {
  ACCEPTED_RISK
  FALSE_POSITIVE
  NOT_APPLICABLE
}

enum SyncJobStatus {
  PENDING
  RUNNING
  POLLING
  DOWNLOADING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum SyncJobTrigger {
  SCHEDULED
  MANUAL
  WEBHOOK
}

// ---------------------------------------------------------------------------
// Tenant Models
// ---------------------------------------------------------------------------

model Organization {
  id                   String    @id @default(cuid()) @map("id")
  name                 String    @map("name")
  slug                 String    @unique @map("slug")
  tier                 Tier      @default(FREE) @map("tier")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  stripeMeteredItemId  String?   @map("stripe_metered_item_id")
  entitlements         Json?     @map("entitlements")
  aiPromptConfig       Json?     @map("ai_prompt_config")
  logoUrl              String?   @map("logo_url")
  domain               String?   @map("domain")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  trialEndsAt          DateTime? @map("trial_ends_at")
  deletedAt            DateTime? @map("deleted_at")

  users               User[]
  clients             Client[]
  teams               Team[]
  assets              Asset[]
  slaPolicies         SlaPolicy[]
  apiKeys             ApiKey[]
  auditLogs           AuditLog[]
  findings            Finding[]
  vulnerabilityCases  VulnerabilityCase[]
  scanArtifacts       ScanArtifact[]
  uploadJobs          UploadJob[]
  brandConfig         BrandConfig?
  reportSchedules     ReportSchedule[]
  pipelineScans       PipelineScan[]
  pipelinePolicy      PipelinePolicy?
  pipelineScanResults PipelineScanResult[]
  pipelineUsage       PipelineUsage[]
  comments            Comment[]
  workflowLineages    WorkflowLineage[]
  riskExceptions      RiskException[]
  tickets             Ticket[]
  notifications       Notification[]
  triageFeedbacks     TriageFeedback[]
  caseApprovals       CaseApproval[]

  @@index([createdAt])
  @@map("organizations")
}

model Client {
  id             String    @id @default(cuid()) @map("id")
  organizationId String    @map("organization_id")
  name           String    @map("name")
  slug           String    @map("slug")
  contactName    String?   @map("contact_name")
  contactEmail   String?   @map("contact_email")
  industry       String?   @map("industry")
  description    String?   @map("description")
  domain         String?   @map("domain")
  tags           String[]  @default([]) @map("tags")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findings              Finding[]
  vulnerabilityCases    VulnerabilityCase[]
  assets                Asset[]
  uploadJobs            UploadJob[]
  scanArtifacts         ScanArtifact[]
  clientTeamAssignments ClientTeamAssignment[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("clients")
}

model User {
  id                 String     @id @default(cuid()) @map("id")
  organizationId     String     @map("organization_id")
  email              String     @map("email")
  name               String     @map("name")
  passwordHash       String?    @map("password_hash")
  googleId           String?    @map("google_id")
  githubId           String?    @map("github_id")
  mfaEnabled         Boolean    @default(false) @map("mfa_enabled")
  mfaSecret          String?    @map("mfa_secret")
  mfaBackupCodes     String[]   @default([]) @map("mfa_backup_codes")
  role               UserRole   @default(VIEWER) @map("role")
  status             UserStatus @default(PENDING_INVITE) @map("status")
  lastLoginAt        DateTime?  @map("last_login_at")
  failedLoginCount   Int        @default(0) @map("failed_login_count")
  accountLockedUntil DateTime?  @map("account_locked_until")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  deletedAt          DateTime?  @map("deleted_at")

  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teamMemberships        TeamMembership[]
  comments               Comment[]
  notifications          Notification[]
  assignedCases          VulnerabilityCase[] @relation("AssignedCases")
  scanArtifacts          ScanArtifact[]
  workflowChanges        WorkflowLineage[]
  riskExceptionsDecided  RiskException[]     @relation("ExceptionDecidedBy")
  riskExceptionsApproved RiskException[]     @relation("ExceptionApprovedBy")
  approvedCases          VulnerabilityCase[] @relation("ApprovedCases")
  triageFeedbacks        TriageFeedback[]    @relation("TriageFeedbackReviewer")
  approvalRequests       CaseApproval[]      @relation("ApprovalRequestedBy")
  approvalDecisions      CaseApproval[]      @relation("ApprovalApprover")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@map("users")
}

model Team {
  id             String   @id @default(cuid()) @map("id")
  organizationId String   @map("organization_id")
  name           String   @map("name")
  description    String?  @map("description")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships       TeamMembership[]
  clientAssignments ClientTeamAssignment[]

  @@index([organizationId])
  @@map("teams")
}

model TeamMembership {
  id        String   @id @default(cuid()) @map("id")
  userId    String   @map("user_id")
  teamId    String   @map("team_id")
  role      TeamRole @default(MEMBER) @map("role")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_memberships")
}

model ClientTeamAssignment {
  id        String   @id @default(cuid()) @map("id")
  teamId    String   @map("team_id")
  clientId  String   @map("client_id")
  createdAt DateTime @default(now()) @map("created_at")

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([teamId, clientId])
  @@map("client_team_assignments")
}

// ---------------------------------------------------------------------------
// Core Domain Models
// ---------------------------------------------------------------------------

model Asset {
  id              String      @id @default(cuid()) @map("id")
  organizationId  String      @map("organization_id")
  clientId        String      @map("client_id")
  name            String      @map("name")
  type            AssetType   @map("type")
  environment     Environment @default(PRODUCTION) @map("environment")
  criticality     Criticality @default(MEDIUM) @map("criticality")
  internetExposed Boolean     @default(false) @map("internet_exposed")
  tags            String[]    @map("tags")
  deploymentRefs  Json?       @map("deployment_refs")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  findings     Finding[]

  @@index([organizationId, clientId])
  @@index([organizationId, type])
  @@index([organizationId, environment])
  @@index([organizationId, deletedAt])
  @@index([clientId])
  @@map("assets")
}

model Finding {
  id                  String      @id @default(cuid()) @map("id")
  organizationId      String      @map("organization_id")
  clientId            String      @map("client_id")
  assetId             String      @map("asset_id")
  scannerType         ScannerType @map("scanner_type")
  scannerName         String      @map("scanner_name")
  runId               String?     @map("run_id")
  observations        Json        @map("observations")
  dedupKey            String      @map("dedup_key")
  vulnerabilityCaseId String?     @map("vulnerability_case_id")
  artifactId          String?     @map("artifact_id")
  discoveredAt        DateTime    @map("discovered_at")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  asset             Asset              @relation(fields: [assetId], references: [id], onDelete: Cascade)
  vulnerabilityCase VulnerabilityCase? @relation(fields: [vulnerabilityCaseId], references: [id], onDelete: SetNull)
  artifact          ScanArtifact?      @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([organizationId, clientId, createdAt])
  @@index([organizationId, scannerType])
  @@index([discoveredAt])
  @@index([clientId])
  @@index([assetId])
  @@index([dedupKey])
  @@index([vulnerabilityCaseId])
  @@index([artifactId])
  @@map("findings")
}

model VulnerabilityCase {
  id               String     @id @default(cuid()) @map("id")
  organizationId   String     @map("organization_id")
  clientId         String     @map("client_id")
  title            String     @map("title")
  description      String?    @map("description")
  cveIds           String[]   @map("cve_ids")
  cweIds           String[]   @map("cwe_ids")
  severity         Severity   @map("severity")
  cvssScore        Float?     @map("cvss_score")
  cvssVector       String?    @map("cvss_vector")
  cvssVersion      String?    @map("cvss_version")
  epssScore        Float?     @map("epss_score")
  epssPercentile   Float?     @map("epss_percentile")
  kevListed        Boolean    @default(false) @map("kev_listed")
  kevDueDate       DateTime?  @map("kev_due_date")
  status           CaseStatus @default(NEW) @map("status")
  assignedToId     String?    @map("assigned_to_id")
  slaPolicyId      String?    @map("sla_policy_id")
  dueAt            DateTime?  @map("due_at")
  aiAdvisory       Json?      @map("ai_advisory")
  remediationNotes String?    @map("remediation_notes")
  findingCount     Int        @default(0) @map("finding_count")
  firstSeenAt      DateTime   @map("first_seen_at")
  lastSeenAt       DateTime   @map("last_seen_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  // Triage feedback
  severityOverride Severity? @map("severity_override")
  triageVerdict    String?   @map("triage_verdict") // AI verdict: TRUE_POSITIVE, FALSE_POSITIVE, NEEDS_REVIEW
  triageConfidence Float?    @map("triage_confidence")
  triageModel      String?   @map("triage_model")
  triageAt         DateTime? @map("triage_at")

  // Approval workflow
  requiresApproval Boolean   @default(false) @map("requires_approval")
  approvalStatus   String?   @map("approval_status") // PENDING, APPROVED, REJECTED
  approvedById     String?   @map("approved_by_id")
  approvedAt       DateTime? @map("approved_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo       User?             @relation("AssignedCases", fields: [assignedToId], references: [id], onDelete: SetNull)
  slaPolicy        SlaPolicy?        @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  findings         Finding[]
  comments         Comment[]
  workflowLineages WorkflowLineage[]
  riskExceptions   RiskException[]
  tickets          Ticket[]
  approvedBy       User?             @relation("ApprovedCases", fields: [approvedById], references: [id], onDelete: SetNull)
  triageFeedbacks  TriageFeedback[]
  caseApprovals    CaseApproval[]

  @@index([organizationId, clientId])
  @@index([organizationId, clientId, status])
  @@index([organizationId, status])
  @@index([organizationId, severity])
  @@index([organizationId, severity, status])
  @@index([organizationId, triageVerdict])
  @@index([organizationId, dueAt])
  @@index([clientId])
  @@index([assignedToId])
  @@index([slaPolicyId])
  @@index([organizationId, approvalStatus])
  @@map("vulnerability_cases")
}

// ---------------------------------------------------------------------------
// Scan Pipeline Models
// ---------------------------------------------------------------------------

model ScanArtifact {
  id             String       @id @default(cuid()) @map("id")
  organizationId String       @map("organization_id")
  clientId       String       @map("client_id")
  filename       String       @map("filename")
  mimeType       String       @map("mime_type")
  sizeBytes      Int          @map("size_bytes")
  gcsBucket      String       @map("gcs_bucket")
  gcsPath        String       @map("gcs_path")
  checksumSha256 String       @map("checksum_sha256")
  parserFormat   ParserFormat @map("parser_format")
  uploadedById   String       @map("uploaded_by_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  findings     Finding[]
  uploadJobs   UploadJob[]

  @@index([organizationId, clientId])
  @@map("scan_artifacts")
}

model UploadJob {
  id                 String          @id @default(cuid()) @map("id")
  organizationId     String          @map("organization_id")
  clientId           String          @map("client_id")
  artifactId         String          @map("artifact_id")
  status             UploadJobStatus @default(QUEUED) @map("status")
  totalFindings      Int             @default(0) @map("total_findings")
  parsedFindings     Int             @default(0) @map("parsed_findings")
  uniqueCvesFound    Int             @default(0) @map("unique_cves_found")
  uniqueCvesEnriched Int             @default(0) @map("unique_cves_enriched")
  findingsCreated    Int             @default(0) @map("findings_created")
  casesCreated       Int             @default(0) @map("cases_created")
  errorMessage       String?         @map("error_message")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  completedAt        DateTime?       @map("completed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  artifact     ScanArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([organizationId, clientId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([artifactId])
  @@map("upload_jobs")
}

// ---------------------------------------------------------------------------
// Collaboration & Workflow Models
// ---------------------------------------------------------------------------

model Comment {
  id                  String    @id @default(cuid()) @map("id")
  organizationId      String    @map("organization_id")
  vulnerabilityCaseId String    @map("vulnerability_case_id")
  userId              String    @map("user_id")
  content             String    @map("content")
  mentions            String[]  @map("mentions")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vulnerabilityCase VulnerabilityCase @relation(fields: [vulnerabilityCaseId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([vulnerabilityCaseId])
  @@map("comments")
}

model WorkflowLineage {
  id                  String     @id @default(cuid()) @map("id")
  organizationId      String     @map("organization_id")
  vulnerabilityCaseId String     @map("vulnerability_case_id")
  fromStatus          CaseStatus @map("from_status")
  toStatus            CaseStatus @map("to_status")
  changedById         String?    @map("changed_by_id")
  reason              String?    @map("reason")
  metadata            Json?      @map("metadata")
  createdAt           DateTime   @default(now()) @map("created_at")

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vulnerabilityCase VulnerabilityCase @relation(fields: [vulnerabilityCaseId], references: [id], onDelete: Cascade)
  changedBy         User?             @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([vulnerabilityCaseId])
  @@map("workflow_lineages")
}

// ---------------------------------------------------------------------------
// Triage Feedback — persists human corrections to AI triage decisions
// ---------------------------------------------------------------------------

model TriageFeedback {
  id                  String    @id @default(cuid()) @map("id")
  organizationId      String    @map("organization_id")
  vulnerabilityCaseId String    @map("vulnerability_case_id")
  reviewerId          String    @map("reviewer_id")
  originalVerdict     String    @map("original_verdict")
  originalSeverity    Severity  @map("original_severity")
  originalConfidence  Float     @map("original_confidence")
  correctedVerdict    String?   @map("corrected_verdict")
  correctedSeverity   Severity? @map("corrected_severity")
  outcome             String    @map("outcome") // APPROVED, REJECTED, MODIFIED
  reason              String?   @map("reason")
  createdAt           DateTime  @default(now()) @map("created_at")

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vulnerabilityCase VulnerabilityCase @relation(fields: [vulnerabilityCaseId], references: [id], onDelete: Cascade)
  reviewer          User              @relation("TriageFeedbackReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([vulnerabilityCaseId])
  @@index([organizationId, outcome])
  @@map("triage_feedback")
}

// ---------------------------------------------------------------------------
// Case Approval — approval gate for case status transitions
// ---------------------------------------------------------------------------

model CaseApproval {
  id                  String    @id @default(cuid()) @map("id")
  organizationId      String    @map("organization_id")
  vulnerabilityCaseId String    @map("vulnerability_case_id")
  requestedById       String    @map("requested_by_id")
  requestedTransition String    @map("requested_transition") // e.g. "TRIAGE->IN_REMEDIATION"
  approverId          String?   @map("approver_id")
  decision            String?   @map("decision") // APPROVED, REJECTED
  reason              String?   @map("reason")
  requestedAt         DateTime  @default(now()) @map("requested_at")
  decidedAt           DateTime? @map("decided_at")

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vulnerabilityCase VulnerabilityCase @relation(fields: [vulnerabilityCaseId], references: [id], onDelete: Cascade)
  requestedBy       User              @relation("ApprovalRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  approver          User?             @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([vulnerabilityCaseId])
  @@index([organizationId, decision])
  @@map("case_approvals")
}

model RiskException {
  id                  String        @id @default(cuid()) @map("id")
  organizationId      String        @map("organization_id")
  vulnerabilityCaseId String        @map("vulnerability_case_id")
  type                ExceptionType @map("type")
  decidedById         String        @map("decided_by_id")
  reason              String        @map("reason")
  evidence            Json?         @map("evidence")
  approvedById        String?       @map("approved_by_id")
  expiresAt           DateTime?     @map("expires_at")
  vexRationale        String?       @map("vex_rationale")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vulnerabilityCase VulnerabilityCase @relation(fields: [vulnerabilityCaseId], references: [id], onDelete: Cascade)
  decidedBy         User              @relation("ExceptionDecidedBy", fields: [decidedById], references: [id], onDelete: Cascade)
  approvedBy        User?             @relation("ExceptionApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([vulnerabilityCaseId])
  @@map("risk_exceptions")
}

model Ticket {
  id                  String    @id @default(cuid()) @map("id")
  organizationId      String    @map("organization_id")
  vulnerabilityCaseId String    @map("vulnerability_case_id")
  system              String    @map("system")
  ticketKey           String    @map("ticket_key")
  ticketUrl           String    @map("ticket_url")
  status              String    @map("status")
  assignee            String?   @map("assignee")
  dueDate             DateTime? @map("due_date")
  syncedAt            DateTime  @map("synced_at")
  lastSyncError       String?   @map("last_sync_error")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vulnerabilityCase VulnerabilityCase @relation(fields: [vulnerabilityCaseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([vulnerabilityCaseId])
  @@map("tickets")
}

// ---------------------------------------------------------------------------
// Policy & Configuration Models
// ---------------------------------------------------------------------------

model SlaPolicy {
  id              String   @id @default(cuid()) @map("id")
  organizationId  String   @map("organization_id")
  name            String   @map("name")
  description     String?  @map("description")
  criticalDays    Int      @map("critical_days")
  highDays        Int      @map("high_days")
  mediumDays      Int      @map("medium_days")
  lowDays         Int      @map("low_days")
  kevCriticalDays Int      @map("kev_critical_days")
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vulnerabilityCases VulnerabilityCase[]

  @@index([organizationId])
  @@map("sla_policies")
}

model ApiKey {
  id                 String    @id @default(cuid()) @map("id")
  organizationId     String    @map("organization_id")
  name               String    @map("name")
  keyHash            String    @map("key_hash")
  scope              String    @map("scope")
  assignedClients    String[]  @map("assigned_clients")
  expiresAt          DateTime? @map("expires_at")
  rotationRequiredBy DateTime? @map("rotation_required_by")
  lastUsedAt         DateTime? @map("last_used_at")
  requestCount       Int       @default(0) @map("request_count")
  lastErrorAt        DateTime? @map("last_error_at")
  errorCount         Int       @default(0) @map("error_count")
  createdAt          DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([keyHash])
  @@map("api_keys")
}

// ---------------------------------------------------------------------------
// Audit & Notification Models
// ---------------------------------------------------------------------------

model AuditLog {
  id             String      @id @default(cuid()) @map("id")
  organizationId String      @map("organization_id")
  entityType     String      @map("entity_type")
  entityId       String      @map("entity_id")
  action         AuditAction @map("action")
  actorId        String      @map("actor_id")
  actorIp        String?     @map("actor_ip")
  details        Json        @map("details")
  hash           String      @map("hash")
  previousHash   String?     @map("previous_hash")
  createdAt      DateTime    @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, entityType, entityId])
  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id                String    @id @default(cuid()) @map("id")
  organizationId    String    @map("organization_id")
  userId            String    @map("user_id")
  type              String    @map("type")
  title             String    @map("title")
  message           String    @map("message")
  relatedEntityType String?   @map("related_entity_type")
  relatedEntityId   String?   @map("related_entity_id")
  isRead            Boolean   @default(false) @map("is_read")
  createdAt         DateTime  @default(now()) @map("created_at")
  readAt            DateTime? @map("read_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Report Schedule Model
// ---------------------------------------------------------------------------

model ReportSchedule {
  id             String    @id @default(cuid()) @map("id")
  organizationId String    @map("organization_id")
  name           String    @map("name")
  clientId       String?   @map("client_id")
  reportType     String    @map("report_type") // 'executive' | 'findings' | 'sla'
  format         String    @default("csv") @map("format")
  frequency      String    @map("frequency") // 'daily' | 'weekly' | 'monthly'
  recipients     String[]  @map("recipients") // email addresses
  dayOfWeek      Int?      @map("day_of_week")
  hourUtc        Int       @default(0) @map("hour_utc")
  nextRunAt      DateTime  @map("next_run_at")
  lastRunAt      DateTime? @map("last_run_at")
  enabled        Boolean   @default(true) @map("enabled")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([nextRunAt, enabled])
  @@map("report_schedules")
}

