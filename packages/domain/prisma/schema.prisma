// ---------------------------------------------------------------------------
// Sync Job & Log Models (Scanner API Connectors — Wave 15)
// ---------------------------------------------------------------------------

model SyncJob {
  id                   String         @id @default(cuid()) @map("id")
  connectorId          String         @map("connector_id")
  organizationId       String         @map("organization_id")
  clientId             String?        @map("client_id")
  status               SyncJobStatus  @default(PENDING) @map("status")
  trigger              SyncJobTrigger @default(SCHEDULED) @map("trigger")
  externalJobId        String?        @map("external_job_id")
  totalChunks          Int            @default(0) @map("total_chunks")
  processedChunks      Int            @default(0) @map("processed_chunks")
  findingsReceived     Int            @default(0) @map("findings_received")
  findingsCreated      Int            @default(0) @map("findings_created")
  findingsDeduplicated Int            @default(0) @map("findings_deduplicated")
  casesCreated         Int            @default(0) @map("cases_created")
  casesUpdated         Int            @default(0) @map("cases_updated")
  errorMessage         String?        @map("error_message")
  metadata             Json?          @map("metadata")
  startedAt            DateTime?      @map("started_at")
  completedAt          DateTime?      @map("completed_at")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  connector ScannerConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  logs      SyncLog[]

  @@index([connectorId])
  @@index([organizationId, createdAt])
  @@index([status])
  @@map("sync_jobs")
}

model SyncLog {
  id        String   @id @default(cuid()) @map("id")
  syncJobId String   @map("sync_job_id")
  level     String   @map("level") // info, warn, error
  message   String   @map("message")
  metadata  Json?    @map("metadata")
  createdAt DateTime @default(now()) @map("created_at")

  syncJob SyncJob @relation(fields: [syncJobId], references: [id], onDelete: Cascade)

  @@index([syncJobId, createdAt])
  @@map("sync_logs")
}

// ---------------------------------------------------------------------------
// Pipeline Scan Model (w21t8)
// ---------------------------------------------------------------------------

enum PipelineScanType {
  SAST
  SCA
  CONTAINER
  SECRETS
}

enum PipelineScanStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum PipelineScanTrigger {
  PUSH
  PR
  SCHEDULE
  MANUAL
}

model PipelineScan {
  id             String              @id @default(cuid()) @map("id")
  organizationId String              @map("organization_id")
  repository     String              @map("repository")
  branch         String              @map("branch")
  commitSha      String              @map("commit_sha")
  scanType       PipelineScanType    @map("scan_type")
  status         PipelineScanStatus  @default(QUEUED) @map("status")
  startedAt      DateTime?           @map("started_at")
  completedAt    DateTime?           @map("completed_at")
  findingsCount  Int                 @default(0) @map("findings_count")
  criticalCount  Int                 @default(0) @map("critical_count")
  highCount      Int                 @default(0) @map("high_count")
  mediumCount    Int                 @default(0) @map("medium_count")
  lowCount       Int                 @default(0) @map("low_count")
  triggeredBy    PipelineScanTrigger @default(PUSH) @map("triggered_by")
  prNumber       Int?                @map("pr_number")
  errorMessage   String?             @map("error_message")
  metadata       Json?               @map("metadata")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, repository])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@map("pipeline_scans")
}

// ---------------------------------------------------------------------------
// Pipeline Policy — per-org compliance policy for CI/CD scans
// ---------------------------------------------------------------------------

model PipelinePolicy {
  id                      String   @id @default(cuid()) @map("id")
  organizationId          String   @unique @map("organization_id")
  frameworks              Json     @default("[\"nist-800-53\"]") @map("frameworks")
  blockOnSeverity         String   @default("CRITICAL") @map("block_on_severity")
  blockOnControlViolation Boolean  @default(false) @map("block_on_control_violation")
  warnOnly                Boolean  @default(false) @map("warn_only")
  autoExceptionRules      Json     @default("[]") @map("auto_exception_rules")
  gracePeriodDays         Int      @default(0) @map("grace_period_days")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("pipeline_policies")
}

// ---------------------------------------------------------------------------
// Pipeline Scan Result — persisted output from /api/pipeline/scan
// ---------------------------------------------------------------------------

model PipelineScanResult {
  id                 String   @id @map("id")
  organizationId     String   @map("organization_id")
  format             String   @map("format")
  repoUrl            String?  @map("repo_url")
  commitSha          String?  @map("commit_sha")
  branch             String?  @map("branch")
  prNumber           Int?     @map("pr_number")
  verdict            String   @map("verdict")
  totalFindings      Int      @default(0) @map("total_findings")
  criticalCount      Int      @default(0) @map("critical_count")
  highCount          Int      @default(0) @map("high_count")
  mediumCount        Int      @default(0) @map("medium_count")
  lowCount           Int      @default(0) @map("low_count")
  infoCount          Int      @default(0) @map("info_count")
  complianceImpact   Json     @default("[]") @map("compliance_impact")
  policyReasons      Json     @default("[]") @map("policy_reasons")
  poamEntriesCreated Int      @default(0) @map("poam_entries_created")
  findings           Json     @default("[]") @map("findings")
  createdAt          DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, verdict])
  @@index([organizationId, repoUrl])
  @@map("pipeline_scan_results")
}

// ---------------------------------------------------------------------------
// Pipeline Usage — monthly counters for tier-gated features
// ---------------------------------------------------------------------------

model PipelineUsage {
  id             String   @id @default(cuid()) @map("id")
  organizationId String   @map("organization_id")
  month          String   @map("month") // YYYY-MM format
  prCommentsUsed Int      @default(0) @map("pr_comments_used")
  uploadsUsed    Int      @default(0) @map("uploads_used")
  scansRun       Int      @default(0) @map("scans_run")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, month])
  @@index([organizationId, month])
  @@map("pipeline_usage")
}
