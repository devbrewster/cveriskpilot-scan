// ---------------------------------------------------------------------------
// Scanner Connector Model (t97)
// ---------------------------------------------------------------------------

model ScannerConnector {
  id                  String    @id @default(cuid()) @map("id")
  organizationId      String    @map("organization_id")
  name                String    @map("name")
  type                String    @map("type") // nessus, qualys, openvas, generic, TENABLE_IO, QUALYS_VMDR, etc.
  endpoint            String    @map("endpoint")
  authConfig          Json      @map("auth_config")
  authKeyHash         String    @map("auth_key_hash")
  schedule            String?   @map("schedule")
  lastHeartbeat       DateTime? @map("last_heartbeat")
  lastHeartbeatData   Json?     @map("last_heartbeat_data")
  status              String    @default("pending") @map("status") // online, offline, degraded, pending
  metadata            Json?     @map("metadata")
  clientId            String?   @map("client_id")
  syncIntervalMinutes Int       @default(60) @map("sync_interval_minutes")
  lastSyncAt          DateTime? @map("last_sync_at")
  lastSyncError       String?   @map("last_sync_error")
  isApiConnector      Boolean   @default(false) @map("is_api_connector")
  scannerConfig       Json?     @map("scanner_config")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  syncJobs SyncJob[]

  @@index([organizationId])
  @@index([authKeyHash])
  @@map("scanner_connectors")
}

// ---------------------------------------------------------------------------
// White-Label Brand Configuration (t-whitelabel)
